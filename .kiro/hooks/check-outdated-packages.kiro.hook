{
  "enabled": true,
  "name": "Check Outdated NPM Packages",
  "description": "Monitors package.json for changes and checks for outdated npm packages, alerting you to available updates for dependencies",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "package.json"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "pnpm outdated"
  }
}
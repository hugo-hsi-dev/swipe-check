{
  "mcpServers": {
    "svelte": {
      "command": "npx",
      "args": [
        "-y",
        "@sveltejs/mcp"
      ],
      "disabled": false
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "disabled": false
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--executablePath=/usr/bin/google-chrome",
        "--headless"
      ],
      "disabled": false,
      "autoApprove": [
        "list_pages",
        "new_page",
        "take_snapshot",
        "take_screenshot",
        "navigate_page"
      ]
    }
  }
}
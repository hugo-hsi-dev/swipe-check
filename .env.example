# Database
DATABASE_URL=postgresql://user:password@localhost:5432/swipe_check

# Example for local development:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/swipe_check

# Example for production (Neon, Supabase, etc):
# DATABASE_URL=postgresql://username:password@hostname:5432/database?sslmode=require

# Better Auth
# Generate a random secret for cookie signing (use: openssl rand -base64 32)
BETTER_AUTH_SECRET=your-secret-key-here-change-in-production
